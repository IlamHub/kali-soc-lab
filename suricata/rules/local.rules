# ===========================
# KALI SOC LAB - Custom Rules
# Written by: YOUR NAME
# ===========================

# --- RECONNAISSANCE ---

# Detect ICMP ping sweep (attacker mapping the network)
alert icmp any any -> $HOME_NET any (msg:"[SOC-LAB] ICMP Ping Detected"; itype:8; classtype:network-scan; sid:1000001; rev:1;)

# Detect Nmap SYN scan (most common recon technique)
alert tcp any any -> $HOME_NET any (msg:"[SOC-LAB] Nmap SYN Scan Detected"; flags:S,12; threshold:type threshold, track by_src, count 20, seconds 3; classtype:network-scan; sid:1000002; rev:1;)

# Detect Nmap version scan (-sV flag sends specific probes)
alert tcp any any -> $HOME_NET any (msg:"[SOC-LAB] Nmap Version Scan Detected"; flags:S; threshold:type both, track by_src, count 50, seconds 5; classtype:network-scan; sid:1000003; rev:1;)

# --- BRUTE FORCE ---

# Detect SSH brute force (too many connection attempts)
alert tcp any any -> $HOME_NET 22 (msg:"[SOC-LAB] SSH Brute Force Attempt"; flags:S; threshold:type threshold, track by_src, count 5, seconds 60; classtype:attempted-admin; sid:1000004; rev:1;)

# Detect HTTP login brute force against DVWA
alert http any any -> $HOME_NET 8080 (msg:"[SOC-LAB] HTTP Brute Force Against DVWA"; http.method; content:"POST"; http.uri; content:"/dvwa/login.php"; threshold:type threshold, track by_src, count 10, seconds 30; classtype:attempted-admin; sid:1000005; rev:1;)

# --- WEB ATTACKS ---

# Detect Nikto web scanner by its user-agent
alert http any any -> $HOME_NET 8080 (msg:"[SOC-LAB] Nikto Web Scanner Detected"; http.user_agent; content:"Nikto"; nocase; classtype:web-application-attack; sid:1000006; rev:1;)

# Detect SQL Injection attempt (UNION-based)
alert http any any -> $HOME_NET 8080 (msg:"[SOC-LAB] SQL Injection - UNION SELECT"; http.uri; content:"UNION"; nocase; content:"SELECT"; nocase; classtype:web-application-attack; sid:1000007; rev:1;)

# Detect SQL Injection (comment-based, -- or #)
alert http any any -> $HOME_NET 8080 (msg:"[SOC-LAB] SQL Injection - Comment Bypass"; http.uri; pcre:"/(\-\-|%23|%27)/i"; classtype:web-application-attack; sid:1000008; rev:1;)

# Detect Directory Traversal attempt
alert http any any -> $HOME_NET 8080 (msg:"[SOC-LAB] Directory Traversal Attempt"; http.uri; content:"../"; classtype:web-application-attack; sid:1000009; rev:1;)

# Detect XSS attempt
alert http any any -> $HOME_NET 8080 (msg:"[SOC-LAB] XSS Attempt Detected"; http.uri; content:"<script>"; nocase; classtype:web-application-attack; sid:1000010; rev:1;)

# Detect command injection attempt
alert http any any -> $HOME_NET 8080 (msg:"[SOC-LAB] Command Injection Attempt"; http.uri; pcre:"/(;|\||\`|&&).*(ls|cat|id|whoami|pwd|wget|curl)/i"; classtype:web-application-attack; sid:1000011; rev:1;)
